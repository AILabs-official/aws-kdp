# =============================================================================
# KDP Coloring Book Generator — Environment Variables
# =============================================================================
# Copy this file to `.env` (cùng repo root) và điền giá trị thật.
# `.env` đã được .gitignore — KHÔNG commit token thật lên Git.
#
# Mỗi block dưới đây là 1 nhóm tính năng — chỉ cần điền block bạn dùng.
# =============================================================================


# -----------------------------------------------------------------------------
# 1) IMAGE RENDERER — bắt buộc nếu chạy generate_images.py / cover-designer
# -----------------------------------------------------------------------------
# Chọn 1 renderer. Chỉ cần điền KEY tương ứng với cái đang dùng.
#   ai33      → AI3.3 (giá rẻ, ổn định, ưu tiên cho coloring)
#   openai    → OpenAI GPT Image / ChatGPT Images
#   bimai     → BIMAI
#   kie       → KIE.AI
#   nanopic   → Nano Banana Pic (hỗ trợ token pool round-robin)
IMAGE_RENDERER=ai33

# AI3.3 — đăng ký https://ai-3-3.com → Dashboard → API keys
AI33_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI GPT Image — lấy API key tại https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_IMAGE_MODEL=gpt-image-1.5
# OPENAI_IMAGE_QUALITY=high

# BIMAI — đăng ký https://bimai.io → Settings → API
# BIMAI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# KIE.AI — đăng ký https://kie.ai → Profile → API Keys
# KIE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NanoPic — đăng ký https://nanopic.ai → Account → Access Tokens
# Hỗ trợ pool nhiều token (comma-separated) để tăng song song.
# NANOPIC_ACCESS_TOKEN=token1,token2,token3

# Google Gemini (optional) — dùng cho 1 số helper trong scripts/config.py
# Lấy key tại https://aistudio.google.com/apikey
# GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# 2) AUTHOR INFO — bắt buộc cho build_pdf.py + generate_cover.py
# -----------------------------------------------------------------------------
# Tên tác giả/publisher in lên title page, copyright page, cover, spine.
# KDP yêu cầu metadata khớp tuyệt đối — KHÔNG đổi giữa interior và cover.
AUTHOR_FIRST_NAME=YourBrand
AUTHOR_LAST_NAME=Publishing


# -----------------------------------------------------------------------------
# 3) APIFY — niche research + Amazon competitor scrape (optional, recommended)
# -----------------------------------------------------------------------------
# Dùng cho:
#   - Agent 01 (niche-hunter)        → Amazon BSR, top-10 reviews, price
#   - Agent 07 (performance-analyst) → keyword competitor benchmark
# Đăng ký Apify free tier: https://apify.com → Settings → Integrations → API token
# Free tier $5 credit/tháng đủ cho ~50 niche scan.
# Nếu KHÔNG có token, niche-hunter fallback xuống WebSearch (chậm + ít chính xác).
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# 4) AMAZON ADVERTISING API — chỉ cần khi dùng ads-manager
# -----------------------------------------------------------------------------
# Setup mất 1-3 tuần (Amazon review thủ công). Bỏ qua block này nếu chưa launch
# sách / chưa cần auto-bid. ads-manager vẫn chạy được mà chỉ output CSV upload.
#
# QUY TRÌNH SETUP (one-time, ~30 phút thao tác + chờ duyệt):
#
# Bước 1 — LWA Security Profile
#   → developer.amazon.com → Login With Amazon → Settings → Security Profiles
#   → Create New Security Profile
#   → copy "Client ID"     → ADS_API_CLIENT_ID
#   → copy "Client Secret" → ADS_API_CLIENT_SECRET
#
# Bước 2 — Apply Amazon Ads API access
#   → advertising.amazon.com/API/docs/en-us/setting-up/overview
#   → Submit application form (chờ 1-3 tuần Amazon duyệt)
#
# Bước 3 — Lấy refresh_token (sau khi đã được approve)
#   → python3 scripts/ads_oauth_helper.py
#   → Browser tự mở → click "Allow" → script capture refresh_token
#   → copy token vào ADS_API_REFRESH_TOKEN
#
# Bước 4 — Lấy profileId (US marketplace)
#   → python3 scripts/amazon_ads_api.py list-profiles
#   → tìm dòng countryCode=US → copy profileId → ADS_API_PROFILE_ID
#
# Bước 5 — Verify
#   → python3 scripts/amazon_ads_api.py test-connection
#   → "✅ Connected" = OK
ADS_API_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADS_API_CLIENT_SECRET=amzn1.oa2-cs.v1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADS_API_REFRESH_TOKEN=Atzr|
ADS_API_PROFILE_ID=0000000000000000

# Region của profile:
#   NA = US / CA / MX
#   EU = UK / DE / FR / IT / ES / NL / SE / PL
#   FE = JP / AU
ADS_API_REGION=NA

# Redirect URI MUST khớp với cái đăng ký trong LWA Security Profile (Bước 1).
# Default cho ads_oauth_helper.py là localhost:8765/callback.
ADS_API_REDIRECT_URI=http://localhost:8765/callback
